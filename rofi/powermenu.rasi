* {
    bg0:    #1c1917;
    bg1:    #242120;
    bg2:    #2e2b28;
    border: #3a3735;
    fg0:    #e7e3de;
    fg1:    #9d9490;
    danger: #ef4444;

    background-color: transparent;
    text-color:       @fg0;
    font:             "Noto Sans 14";
}

window {
    background-color: @bg0;
    border:           1px;
    border-color:     @border;
    border-radius:    14px;
    width:            300px;
    padding:          12px;
}

mainbox {
    background-color: transparent;
    spacing:          8px;
    padding:          0px;
    children:         [message, listview];
}

message {
    background-color: transparent;
    padding:          0px 0px 4px 0px;
}

textbox {
    background-color: transparent;
    text-color:       @fg1;
    font:             "Noto Sans 11";
    horizontal-align: 0.5;
}

listview {
    background-color: transparent;
    columns:          1;
    lines:            5;
    scrollbar:        false;
    spacing:          4px;
}

element {
    background-color: @bg1;
    border:           1px;
    border-color:     @border;
    border-radius:    8px;
    padding:          10px 16px;
    orientation:      horizontal;
    spacing:          0px;
}

element selected {
    background-color: @bg2;
    border-color:     @danger;
    text-color:       @danger;
}

element-text {
    background-color: transparent;
    text-color:       inherit;
    horizontal-align: 0.0;
    highlight:        none;
}
