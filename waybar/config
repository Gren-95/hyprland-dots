{
    "layer": "top",
    "position": "top",
    "height": 36,
    "margin-top": 4,
    "margin-left": 4,
    "margin-right": 4,
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "modules-left": [
        "custom/ppmenu",
        "custom/sep",
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "clock#date",
        "clock#time"
    ],
    "modules-right": [
        "tray",
        "custom/trayscale",
        "custom/sep",
        "custom/bluetooth",
        "custom/sep",
        "pulseaudio",
        "custom/sep",
        "custom/powerprofile",
        "custom/sep",
        "battery",
        "custom/wayvnc",
        "custom/microphone",
        "custom/sep",
        "custom/powermenu"
    ],
    "custom/ppmenu": {
        "format": "¾░Ć╗",
        "tooltip": "Open app menu",
        "tooltip-format": "Open app menu",
        "on-click": "rofi -show drun -show-icons -theme ~/.config/rofi/launcher.rasi"
    },
    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "on-scroll-up": "hyprctl dispatch workspace e+1",
        "on-scroll-down": "hyprctl dispatch workspace e-1",
        "format-icons": {
            "1": "’äĀ",
            "2": "’ē®",
            "3": "’ü╝",
            "4": "’äĪ",
            "5": "’Ćü",
            "6": "’å╝",
            "7": "’ć╝",
            "8": "’äø",
            "9": "’åČ",
            "default": "’åÆ"
        },
        "dynamic": true
    },
    "hyprland/window": {
        "max-length": 40,
        "separate-outputs": true,
        "format": "{title}"
    },
    "clock#date": {
        "format": "  {:%a, %d %b}",
        "tooltip": false,
        "on-click": "gnome-calendar"
    },

    "clock#time": {
        "format": "{:%H:%M}",
        "tooltip-format": "Estonia/Tallinn ŌĆö UTC+3",
        "interval": 1,
        "on-click": "gnome-calendar"
    },
    "pulseaudio": {
        "format": "¾░ĢŠ {volume}%",
        "format-muted": "¾░¢ü muted",
        "on-click": "pavucontrol",
        "format-icons": {
            "default": [
                "¾░Ģ┐",
                "¾░¢Ć",
                "¾░ĢŠ"
            ]
        },
        "scroll-step": 5
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "¾░éä {capacity}%",
        "format-plugged": "¾░éÅ {capacity}%",
        "format-alt": "{icon} {time} left",
        "format-icons": [
            "¾░éÄ",
            "¾░ü║",
            "¾░üŠ",
            "¾░éĆ",
            "¾░ü╣"
        ],
        "interval": 30,
        "states": {
            "critical": 20
        },
        "on-scroll-up": "swayosd-client --brightness raise",
        "on-scroll-down": "swayosd-client --brightness lower"
    },
    "tray": {
        "icon-size": 20,
        "spacing": 10
    },
    "custom/notifications": {
        "format": "{icon}",
        "format-icons": {
            "notification": "¾░é×",
            "none": "¾░éÜ",
            "dnd-notification": "¾░éø",
            "dnd-none": "¾░éø",
            "inhibited-notification": "¾░é×",
            "inhibited-none": "¾░éÜ",
            "dnd-inhibited-notification": "¾░éø",
            "dnd-inhibited-none": "¾░éø"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client --subscribe-waybar",
        "on-click": "swaync-client --toggle-panel --skip-wait",
        "on-click-right": "swaync-client --toggle-dnd --skip-wait",
        "escape": true
    },
    "custom/bluetooth": {
        "format": "{}",
        "return-type": "json",
        "interval": 10,
        "exec": "bash ~/.config/scripts/bluetooth-status.sh",
        "signal": 8,
        "on-scroll-up": "bash ~/.config/scripts/bluetooth-status.sh scroll-up",
        "on-scroll-down": "bash ~/.config/scripts/bluetooth-status.sh scroll-down",
        "on-click": "bash ~/.config/scripts/bluetooth.sh"
    },
    "custom/sep": {
        "format": "Ōöé",
        "interval": "once",
        "tooltip": false
    },
    "custom/clipboard": {
        "format": "¾░ģŹ",
        "tooltip": true,
        "tooltip-format": "Open clipboard history",
        "on-click": "cliphist list | rofi -dmenu -p Clipboard -theme ~/.config/rofi/clipboard.rasi | cliphist decode | wl-copy"
    },
    "custom/colorpicker": {
        "format": "¾░łŖ",
        "tooltip": true,
        "tooltip-format": "Pick a color (copies to clipboard)",
        "on-click": "hyprpicker -a"
    },
    "custom/hypridle": {
        "format": "{}",
        "interval": 5,
        "exec": "if pgrep -x hypridle > /dev/null; then echo '¾░Æ│'; else echo '¾░Æ▓'; fi",
        "tooltip": true,
        "tooltip-format": "Click to toggle idle management",
        "on-click": "if pgrep -x hypridle > /dev/null; then pkill hypridle && notify-send -u low 'Stay Awake' 'Idle management disabled' -i system-suspend-inhibited; else hypridle & notify-send -u low 'Sleep Mode' 'Idle management enabled' -i system-suspend-uninhibited; fi"
    },
    "custom/powerprofile": {
        "format": "{}",
        "return-type": "json",
        "interval": 5,
        "exec": "profile=$(powerprofilesctl get); if [ \"$profile\" = \"performance\" ]; then echo '{\"text\": \"¾▒Éŗ\", \"tooltip\": \"Performance\", \"class\": \"performance\"}'; elif [ \"$profile\" = \"balanced\" ]; then echo '{\"text\": \"¾░Šģ\", \"tooltip\": \"Balanced\", \"class\": \"balanced\"}'; else echo '{\"text\": \"¾▒¤”\", \"tooltip\": \"Power Saver\", \"class\": \"power-saver\"}'; fi",
        "on-click": "current=$(powerprofilesctl get); if [ \"$current\" = \"performance\" ]; then powerprofilesctl set balanced && notify-send -u low 'Power Profile' 'Set to Balanced'; elif [ \"$current\" = \"balanced\" ]; then powerprofilesctl set power-saver && notify-send -u low 'Power Profile' 'Set to Power Saver'; else powerprofilesctl set performance && notify-send -u low 'Power Profile' 'Set to Performance'; fi",
        "on-scroll-up": "brightnessctl --device='dell::kbd_backlight' set +1",
        "on-scroll-down": "brightnessctl --device='dell::kbd_backlight' set 1-"
    },
    "custom/wayvnc": {
        "format": "¾░ó╣",
        "tooltip": true,
        "tooltip-format": "WayVNC active ŌĆö click to stop",
        "interval": 3,
        "exec": "echo ''",
        "exec-if": "pgrep -x wayvnc",
        "on-click": "pkill wayvnc && notify-send -u low -i network-vpn 'WayVNC' 'Remote access stopped'"
    },
    "custom/microphone": {
        "format": "¾░Ź¼",
        "interval": 2,
        "exec": "echo ''",
        "exec-if": "pactl get-source-mute @DEFAULT_SOURCE@ 2>/dev/null | grep -q 'Mute: no'",
        "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
        "tooltip": false
    },
    "custom/powermenu": {
        "format": "ŌÅ╗",
        "tooltip-format": "Power menu",
        "on-click": "bash ~/.config/scripts/powermenu.sh"
    },
    "custom/trayscale": {
        "format": "{}",
        "return-type": "json",
        "interval": 5,
        "exec": "bash ~/.config/scripts/trayscale-status.sh",
        "signal": 9,
        "on-click": "bash ~/.config/scripts/trayscale-status.sh click",
        "on-click-middle": "bash ~/.config/scripts/trayscale-status.sh toggle",
        "on-scroll-up": "bash ~/.config/scripts/trayscale-status.sh scroll-up",
        "on-scroll-down": "bash ~/.config/scripts/trayscale-status.sh scroll-down",
        "tooltip": true
    }
}